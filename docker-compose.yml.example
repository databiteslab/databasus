version: "3"

# Do not use this file in production or VPS. This
# file is indended for local development only. To 
# run on your machine - read README.md

services:
  # For local development only to test build. Do
  # not use in production or VPS
  databasus-local:
    build:
      context: .
      dockerfile: Dockerfile
    ports:
      - "4005:4005"
    volumes:
      - ./databasus-data:/databasus-data
    container_name: databasus-local
    restart: unless-stopped
    environment:
      # Comma-separated list of tables to exclude from all PostgreSQL backups
      # Supports pg_dump patterns (e.g. "public.logs_*,public.temp_*")
      # BACKUP_EXCLUDE_TABLES: "schema.table1,schema.table2"
      #
      # Comma-separated list of tables to include (backup ONLY these tables)
      # BACKUP_INCLUDE_TABLES: "public.important_table"
      #
      # Whether the stale pg_dump session watchdog runs at all. Default: true
      # BACKUP_STALE_SESSION_WATCHDOG_ENABLED: "true"
      #
      # How often (in minutes) to scan PostgreSQL databases for stuck pg_dump
      # sessions. Default: 10
      # BACKUP_STALE_SESSION_CHECK_INTERVAL_MINUTES: "10"
      #
      # Maximum age (in hours) a pg_dump session may reach before it is
      # terminated via pg_terminate_backend. Stuck pg_dump sessions hold locks
      # that can block schema migrations (ALTER TABLE) indefinitely.
      # IMPORTANT: this must be set higher than your largest database's
      # realistic backup duration, or the watchdog will kill a legitimate,
      # still-progressing backup. The conservative default (12h) is safe for
      # most deployments; lower it (e.g. to 2-4h) once you know your actual
      # backup durations for faster protection against stuck sessions.
      # Default: 12
      # BACKUP_STALE_SESSION_MAX_DURATION_HOURS: "12"
      #
      # Maximum runtime (in hours) for a single pg_dump backup attempt before
      # Databasus cancels it. This only bounds the Databasus-side process; it
      # does not by itself guarantee the PostgreSQL backend is terminated too
      # (see BACKUP_STALE_SESSION_MAX_DURATION_HOURS above for that).
      # WARNING: if a database's realistic full backup duration is longer
      # than this value, every backup attempt for it will fail every time.
      # Raise this for deployments with very large databases. Default: 2
      # BACKUP_PG_DUMP_MAX_DURATION_HOURS: "2"